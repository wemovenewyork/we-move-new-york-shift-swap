# ─────────────────────────────────────────────────────────
# We Move NY — Shift Swap  |  Required Environment Variables
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── JWT Secrets ───────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_RESET_SECRET=

# ── App URL (used in emails + push notification deep-links) ──
NEXT_PUBLIC_APP_URL=https://wmnyshiftswap.com

# ── Email (Resend) ────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=We Move NY <noreply@wmnyshiftswap.com>
EMAIL_REPLY_TO=support@wmnyshiftswap.com

# ── Web Push (VAPID) ──────────────────────────────────────
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@wmnyshiftswap.com

# ── Rate Limiting (Upstash Redis) ─────────────────────────
# Create a free Redis DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Cron Job Auth ─────────────────────────────────────────
# Random secret added to all Vercel Cron requests (set in vercel.json + here)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Error Tracking (Sentry) ───────────────────────────────
# Optional but recommended — find these in your Sentry project settings
SENTRY_ORG=
SENTRY_PROJECT=
# DSN for the server runtime; the NEXT_PUBLIC_ copy is inlined into the client
# bundle and is safe to expose (a DSN only permits writes).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only — uploads source maps. Set in CI/Vercel, never in .env.local.
SENTRY_AUTH_TOKEN=

# ── Soft Launch Gate ──────────────────────────────────────
# Comma-separated depot codes allowed to register and sign in while in soft
# launch, e.g. "QV" or "QV,WF,MV". Leave unset to open registration to all.
# SOFT_LAUNCH_DEPOT=QV

# ── Proxy Trust (rate limiting) ───────────────────────────
# Number of proxies in front of the app that append to X-Forwarded-For.
# MUST stay 0 on Vercel: Vercel overwrites the header and does not forward
# client values, so the leftmost entry is trustworthy. Raise this ONLY if you
# put another proxy (Cloudflare, an ALB) in front — otherwise a client can
# spoof its source IP and evade per-IP rate limits. See lib/rateLimit.ts.
# TRUSTED_PROXY_HOPS=0

# ── Build Flags ───────────────────────────────────────────
# Set to "1" only when building a standalone Docker image
# BUILD_STANDALONE=1

# ── Maintenance Mode ──────────────────────────────────────
# Set to "true" to redirect all traffic to /maintenance
# MAINTENANCE_MODE=true

# ── Cron Heartbeat (optional) ─────────────────────────────
# Base ping URL for an uptime monitor (e.g. healthchecks.io). Each cron pings
# ${HEARTBEAT_URL_BASE}/<slug> on success only; a dead cron goes silent and the
# monitor alerts. Leave unset to disable. See RUNBOOK.md → Cron Heartbeat.
# HEARTBEAT_URL_BASE=https://hc-ping.com/your-uuid
