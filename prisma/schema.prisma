generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  depotId        String?  @map("depot_id")
  role           UserRole @default(operator)
  language       String   @default("en")
  avatarUrl      String?  @map("avatar_url")
  verified            Boolean   @default(false)
  emailVerifyToken    String?   @map("email_verify_token")
  emailVerifyExpires  DateTime? @map("email_verify_expires")
  flexibleMode      Boolean   @default(false) @map("flexible_mode")
  flexibleSince     DateTime? @map("flexible_since")
  invitedBy         String?   @map("invited_by")
  termsAcceptedAt   DateTime? @map("terms_accepted_at")
  termsVersion      String?   @map("terms_version")
  loginAttempts     Int       @default(0) @map("login_attempts")
  lockedUntil       DateTime? @map("locked_until")
  suspendedUntil    DateTime? @map("suspended_until")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  depot              Depot?             @relation(fields: [depotId], references: [id])
  inviter            User?              @relation("Invites", fields: [invitedBy], references: [id])
  invitees           User[]             @relation("Invites")
  swaps              Swap[]
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   Message[]          @relation("ReceivedMessages")
  inviteCodes        InviteCode[]       @relation("CodeCreator")
  usedCode           InviteCode?        @relation("CodeUser")
  reputation         Reputation?
  reviewsGiven       Review[]           @relation("ReviewsGiven")
  reviewsReceived    Review[]           @relation("ReviewsReceived")
  reports            Report[]
  pushSubscriptions  PushSubscription[]
  agreementsAsA      SwapAgreement[]    @relation("AgreementUserA")
  agreementsAsB      SwapAgreement[]    @relation("AgreementUserB")
  announcements      Announcement[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  savedSwaps         SavedSwap[]
  lastActiveAt       DateTime? @map("last_active_at")
  jobTitle          String?   @map("job_title")
  depotSetAt        DateTime? @map("depot_set_at")
  verifiedOperator    Boolean   @default(false) @map("verified_operator")
  dispatcherVerified  Boolean   @default(false) @map("dispatcher_verified")
  dispatcherBadge     String?   @map("dispatcher_badge")

  @@map("users")
}

model Depot {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  borough  String
  operator String
  logoUrl  String? @map("logo_url")

  users         User[]
  swaps         Swap[]
  announcements Announcement[]

  @@map("depots")
}

model Announcement {
  id        String    @id @default(uuid())
  depotId   String    @map("depot_id")
  authorId  String    @map("author_id")
  body      String    @db.VarChar(600)
  pinned    Boolean   @default(false)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  depot  Depot @relation(fields: [depotId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

model Swap {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  depotId      String       @map("depot_id")
  category     SwapCategory
  status       SwapStatus   @default(open)
  date         DateTime?    @db.Date
  details      String       @db.VarChar(500)
  contact      String?
  run          String?
  route        String?
  startTime    String?      @map("start_time")
  clearTime    String?      @map("clear_time")
  swingStart   String?      @map("swing_start")
  swingEnd     String?      @map("swing_end")
  fromDay      String?      @map("from_day")
  fromDate     DateTime?    @map("from_date") @db.Date
  toDay        String?      @map("to_day")
  toDate       DateTime?    @map("to_date") @db.Date
  vacationHave String?      @map("vacation_have")
  vacationWant String?      @map("vacation_want")
  posterName   String       @map("poster_name")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user       User            @relation(fields: [userId], references: [id])
  depot      Depot           @relation(fields: [depotId], references: [id])
  messages   Message[]
  reviews    Review[]
  reports    Report[]
  agreements SwapAgreement[]
  savedBy    SavedSwap[]

  @@index([depotId, status, createdAt(sort: Desc)])
  @@map("swaps")
}

model SavedSwap {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  swapId    String   @map("swap_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  swap      Swap     @relation(fields: [swapId], references: [id], onDelete: Cascade)
  @@unique([userId, swapId])
  @@index([userId])
  @@map("saved_swaps")
}

model Message {
  id         String   @id @default(uuid())
  swapId     String?  @map("swap_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  text       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  swap     Swap? @relation(fields: [swapId], references: [id], onDelete: Cascade)
  fromUser User  @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser   User  @relation("ReceivedMessages", fields: [toUserId], references: [id])

  @@map("messages")
}

model InviteCode {
  id        String   @id @default(uuid())
  code      String   @unique
  createdBy String   @map("created_by")
  usedBy    String?  @unique @map("used_by")
  isValid   Boolean  @default(true) @map("is_valid")
  createdAt DateTime @default(now()) @map("created_at")

  creator User  @relation("CodeCreator", fields: [createdBy], references: [id])
  user    User? @relation("CodeUser", fields: [usedBy], references: [id])

  @@map("invite_codes")
}

model Reputation {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  completed Int      @default(0)
  cancelled Int      @default(0)
  noShow    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("reputation")
}

model Review {
  id         String   @id @default(uuid())
  swapId     String   @map("swap_id")
  reviewerId String   @map("reviewer_id")
  reviewedId String   @map("reviewed_id")
  rating     Int
  createdAt  DateTime @default(now()) @map("created_at")

  swap     Swap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewed User @relation("ReviewsReceived", fields: [reviewedId], references: [id])

  @@map("reviews")
}

model Report {
  id         String       @id @default(uuid())
  swapId     String       @map("swap_id")
  reporterId String       @map("reporter_id")
  reason     String?
  status     ReportStatus @default(pending)
  createdAt  DateTime     @default(now()) @map("created_at")

  swap     Swap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  reporter User @relation(fields: [reporterId], references: [id])

  @@map("reports")
}

model SwapAgreement {
  id          String          @id @default(uuid())
  swapId      String          @map("swap_id")
  userAId     String          @map("user_a_id")
  userBId     String          @map("user_b_id")
  status      AgreementStatus @default(pending)
  userANote   String?         @map("user_a_note") @db.VarChar(500)
  userBNote   String?         @map("user_b_note") @db.VarChar(500)
  userAAt     DateTime?       @map("user_a_at")
  userBAt     DateTime?       @map("user_b_at")
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  swap  Swap @relation(fields: [swapId], references: [id], onDelete: Cascade)
  userA User @relation("AgreementUserA", fields: [userAId], references: [id])
  userB User @relation("AgreementUserB", fields: [userBId], references: [id])

  @@map("swap_agreements")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

enum SwapCategory {
  work
  daysoff
  vacation
  open_work
}

enum SwapStatus {
  open
  pending
  filled
  expired
}

enum ReportStatus {
  pending
  reviewed
  dismissed
}

enum UserRole {
  operator
  dispatcher
  depotRep
  subAdmin
  admin
}

enum AgreementStatus {
  pending
  userA_confirmed
  completed
  cancelled
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String
  targetId   String?  @map("target_id")
  targetType String?  @map("target_type")
  detail     String?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

enum AuditAction {
  role_change
  invite_revoke
  invite_generate
  report_dismiss
  report_review
  user_delete
  account_delete
}
